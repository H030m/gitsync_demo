{
  "name": "gitsync-functions",
  "version": "0.0.1",
  "description": "GitSync Cloud Functions (callable + Firestore triggers + webhooks)",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.0.1",
    "openai": "^4.71.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.6.3"
  }
}
