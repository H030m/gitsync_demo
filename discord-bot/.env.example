# GitSync bot config. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit real tokens/secrets.

# 1. Discord bot token (Discord Developer Portal → your app → Bot → Reset Token).
#    The bot must have the "Message Content Intent" enabled in the portal.
DISCORD_BOT_TOKEN=REPLACE_ME

# 2. Shared secret sent as the `x-ingest-secret` header. MUST match the
#    DISCORD_INGEST_SECRET configured for the Cloud Functions
#    (functions/.secret.local for the emulator, or Secret Manager in prod).
DISCORD_INGEST_SECRET=REPLACE_ME

# 3. Single backend switch — keep in sync with the Flutter app's
#    `--dart-define=TARGET=...` so the bot and app hit the same place:
#      cloud     → https://asia-east1-<project>.cloudfunctions.net  (needs deployed functions)
#      emulator  → http://127.0.0.1:5001/<project>/asia-east1        (needs the emulator running)
TARGET=cloud
FIREBASE_PROJECT_ID=gitsync-645b3

# 3b. (Optional) Explicit base URL — overrides TARGET if set (escape hatch).
#FUNCTIONS_BASE_URL=

# 4. (Optional) Backfill poll interval in milliseconds. Default 5000.
#POLL_INTERVAL_MS=5000
