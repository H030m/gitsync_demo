# 複製此檔為 discord.env 並填入真實值

# 1. Forwarder bot 用 — discord.js 連 Discord Gateway
#    取得：Discord Developer Portal → Applications → 你的 App → Bot → Token
DISCORD_BOT_TOKEN=REPLACE_ME

# 2. Ingest 共享密鑰 — forwarder POST 到 discordMessageIngest Cloud Function 時帶 header x-ingest-secret
#    自行生成 32 字隨機字串（PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | %{[char]$_})）
DISCORD_INGEST_SECRET=REPLACE_ME

# 3. (Outbound 通知用的 channel webhook URL 由使用者在 APP 內 setDiscordWebhook 設定，存進 Firestore — 這裡不放)

# 4. (Optional) Forwarder bot 監聽的 channelId → repoId 對照（forwarder bot 自己讀，不進 Functions）
# CHANNEL_REPO_MAP=123456789012345678:team17_gitsync,234567890123456789:team17_other
