# 複製此檔為 github.env 並填入真實值
# (OAuth 模式 — 即課程預設方式 — 不需要這個檔案，Firebase Auth 直接幫你拿到 access token)
# (此檔僅在改用 GitHub App 模式時需要)

# GitHub App 的 App ID
GITHUB_APP_ID=REPLACE_ME

# GitHub App 的 webhook secret（GitHub 推 webhook 時 HMAC 用）
GITHUB_WEBHOOK_SECRET=REPLACE_ME

# Private key 路徑（指向 secrets/github-app-private-key.pem）
# 或直接貼 PEM 內容（換行用 \n）
GITHUB_APP_PRIVATE_KEY_PATH=secrets/github-app-private-key.pem
